# ============================================
# Acrosome Intactness Analysis - Backend Config
# ============================================

# MongoDB Connection
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/acrosome_db?retryWrites=true&w=majority
DATABASE_NAME=acrosome_db

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ML Model
MODEL_PATH=ml_models/acrosome_cnn_model.h5
IMAGE_SIZE=224
CONFIDENCE_THRESHOLD=0.5

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

# PDF Reports
REPORTS_DIR=reports

# Encryption
ENCRYPTION_KEY=your-encryption-key-here
